pipeline {
  agent any

  environment {
    DOCKER_IMAGE = 'tesarect/karthikeyanbalasubramanian-cp22'
    DOCKER_TAG   = 'tortoisebot-noetic-gazebo-v1'
    GAZEBO_STARTUP_TIMEOUT = '60'
  }

  stages {
    stage('Build Docker Image') {
      steps {
        echo "Building Docker image: ${DOCKER_IMAGE}:${DOCKER_TAG}"
        sh 'docker build -t ${DOCKER_IMAGE}:${DOCKER_TAG} .'
      }
    }

    stage('Test - Pass Case') {
      steps {
        echo "Running PASS case test in ${DOCKER_IMAGE}:${DOCKER_TAG}"
        sh '''
          xhost +local:docker || true
          docker run --rm \
            -e DISPLAY=${DISPLAY} \
            -v /tmp/.X11-unix:/tmp/.X11-unix:rw \
            -e GAZEBO_STARTUP_TIMEOUT=${GAZEBO_STARTUP_TIMEOUT} \
            ${DOCKER_IMAGE}:${DOCKER_TAG} bash -lc '
              set -e
              source /opt/ros/noetic/setup.bash
              source /catkin_ws/devel/setup.bash

              export ROS_LOG_DIR=/tmp/roslog
              mkdir -p "$ROS_LOG_DIR"

              echo "Launching Gazebo..."
              roslaunch tortoisebot_gazebo tortoisebot_playground.launch gui:=true headless:=false >/dev/null 2>&1 &

              echo "Waiting for /odom (timeout: ${GAZEBO_STARTUP_TIMEOUT}s)..."
              timeout "${GAZEBO_STARTUP_TIMEOUT}" bash -lc "
                until rostopic echo -n 1 /odom >/dev/null 2>&1; do
                  sleep 1
                done
              " || { echo "ERROR: Timeout waiting for /odom"; exit 1; }

              echo "Simulation ready. Running pass case test..."
              rostest tortoisebot_waypoints waypoints_test.test --reuse-master || true
              echo "Pass case test complete — check output above for result"
            '
        '''
      }
    }

    stage('Test - Fail Case') {
      steps {
        echo "Running FAIL case test in ${DOCKER_IMAGE}:${DOCKER_TAG}"
        sh '''
          xhost +local:docker || true
          docker run --rm \
            -e DISPLAY=${DISPLAY} \
            -v /tmp/.X11-unix:/tmp/.X11-unix:rw \
            -e GAZEBO_STARTUP_TIMEOUT=${GAZEBO_STARTUP_TIMEOUT} \
            ${DOCKER_IMAGE}:${DOCKER_TAG} bash -lc '
              set -e
              source /opt/ros/noetic/setup.bash
              source /catkin_ws/devel/setup.bash

              export ROS_LOG_DIR=/tmp/roslog
              mkdir -p "$ROS_LOG_DIR"

              echo "Launching Gazebo..."
              roslaunch tortoisebot_gazebo tortoisebot_playground.launch gui:=true headless:=false >/dev/null 2>&1 &

              echo "Waiting for /odom (timeout: ${GAZEBO_STARTUP_TIMEOUT}s)..."
              timeout "${GAZEBO_STARTUP_TIMEOUT}" bash -lc "
                until rostopic echo -n 1 /odom >/dev/null 2>&1; do
                  sleep 1
                done
              " || { echo "ERROR: Timeout waiting for /odom"; exit 1; }

              echo "Simulation ready. Running fail case test..."
              rostest tortoisebot_waypoints waypoints_fail_case.test --reuse-master || true
              echo "Fail case test complete — check output above for result"
            '
        '''
      }
    }
  }

  post {
    always {
      sh 'docker image prune -f >/dev/null 2>&1 || true'
    }
    success { echo 'Pipeline completed successfully!' }
    failure { echo 'Pipeline failed!' }
  }
}
